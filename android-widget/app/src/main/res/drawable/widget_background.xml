<?xml version="1.0" encoding="utf-8"?>
<!-- Match web app dark theme: bg=#06070f, border=#1e2140 + cyan glow -->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Dark base -->
    <item>
        <shape android:shape="rectangle">
            <solid android:color="#06070f" />
            <corners android:radius="2dp" />
        </shape>
    </item>
    <!-- Cyan border overlay -->
    <item>
        <shape android:shape="rectangle">
            <solid android:color="#00000000" />
            <stroke android:width="1dp" android:color="#3300ffe7" />
            <corners android:radius="2dp" />
        </shape>
    </item>
</layer-list>
