<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical">

    <!-- Category color accent bar -->
    <View
        android:id="@+id/dialog_accent_bar"
        android:layout_width="match_parent"
        android:layout_height="6dp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingHorizontal="24dp"
        android:paddingTop="18dp"
        android:paddingBottom="8dp">

        <!-- Category pill -->
        <TextView
            android:id="@+id/dialog_category"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:paddingHorizontal="10dp"
            android:paddingVertical="4dp"
            android:textSize="11sp"
            android:textColor="@color/ios_blue"
            android:fontFamily="sans-serif-medium"
            android:background="@drawable/bg_category_pill"
            android:layout_marginBottom="12dp" />

        <!-- Title -->
        <TextView
            android:id="@+id/dialog_title"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="18sp"
            android:textColor="@color/text_primary"
            android:fontFamily="sans-serif-medium"
            android:lineSpacingMultiplier="1.2"
            android:layout_marginBottom="16dp" />

        <!-- Divider -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@color/border_subtle"
            android:layout_marginBottom="12dp" />

        <!-- Date row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="6dp">

            <TextView
                android:layout_width="72dp"
                android:layout_height="wrap_content"
                android:text="날짜"
                android:textSize="12sp"
                android:textColor="@color/text_secondary"
                android:fontFamily="sans-serif-medium" />

            <TextView
                android:id="@+id/dialog_date"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:textSize="13sp"
                android:textColor="@color/text_primary" />
        </LinearLayout>

        <!-- Time row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="6dp">

            <TextView
                android:layout_width="72dp"
                android:layout_height="wrap_content"
                android:text="시간"
                android:textSize="12sp"
                android:textColor="@color/text_secondary"
                android:fontFamily="sans-serif-medium" />

            <TextView
                android:id="@+id/dialog_time"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:textSize="13sp"
                android:textColor="@color/text_primary" />
        </LinearLayout>

        <!-- Module row -->
        <LinearLayout
            android:id="@+id/dialog_row_module"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="6dp"
            android:visibility="gone">

            <TextView
                android:layout_width="72dp"
                android:layout_height="wrap_content"
                android:text="모듈"
                android:textSize="12sp"
                android:textColor="@color/text_secondary"
                android:fontFamily="sans-serif-medium" />

            <TextView
                android:id="@+id/dialog_module"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:textSize="13sp"
                android:textColor="@color/text_primary" />
        </LinearLayout>

        <!-- Instructor row -->
        <LinearLayout
            android:id="@+id/dialog_row_instructor"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="6dp"
            android:visibility="gone">

            <TextView
                android:layout_width="72dp"
                android:layout_height="wrap_content"
                android:text="강사"
                android:textSize="12sp"
                android:textColor="@color/text_secondary"
                android:fontFamily="sans-serif-medium" />

            <TextView
                android:id="@+id/dialog_instructor"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:textSize="13sp"
                android:textColor="@color/text_primary" />
        </LinearLayout>

        <!-- Location row -->
        <LinearLayout
            android:id="@+id/dialog_row_location"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="6dp"
            android:visibility="gone">

            <TextView
                android:layout_width="72dp"
                android:layout_height="wrap_content"
                android:text="장소"
                android:textSize="12sp"
                android:textColor="@color/text_secondary"
                android:fontFamily="sans-serif-medium" />

            <TextView
                android:id="@+id/dialog_location"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:textSize="13sp"
                android:textColor="@color/text_primary" />
        </LinearLayout>

        <!-- Note row -->
        <LinearLayout
            android:id="@+id/dialog_row_note"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="6dp"
            android:visibility="gone">

            <TextView
                android:layout_width="72dp"
                android:layout_height="wrap_content"
                android:text="메모"
                android:textSize="12sp"
                android:textColor="@color/text_secondary"
                android:fontFamily="sans-serif-medium"
                android:paddingTop="1dp" />

            <TextView
                android:id="@+id/dialog_note"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:textSize="13sp"
                android:textColor="@color/text_primary"
                android:lineSpacingMultiplier="1.3" />
        </LinearLayout>

        <!-- Content row -->
        <LinearLayout
            android:id="@+id/dialog_row_content"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="6dp"
            android:visibility="gone">

            <TextView
                android:layout_width="72dp"
                android:layout_height="wrap_content"
                android:text="내용"
                android:textSize="12sp"
                android:textColor="@color/text_secondary"
                android:fontFamily="sans-serif-medium"
                android:paddingTop="1dp" />

            <TextView
                android:id="@+id/dialog_content"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:textSize="13sp"
                android:textColor="@color/text_primary"
                android:lineSpacingMultiplier="1.3" />
        </LinearLayout>

    </LinearLayout>
</LinearLayout>
