<?xml version="1.0" encoding="utf-8"?>
<!-- Cyberpunk weekly calendar widget -->
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_header"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@drawable/widget_background">

    <!-- ── Header: Month / Year ── -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingLeft="14dp"
        android:paddingRight="14dp"
        android:paddingTop="10dp"
        android:paddingBottom="4dp">

        <TextView
            android:id="@+id/widget_month"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="4월"
            android:textColor="#00FFE7"
            android:textSize="14sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/widget_year"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginLeft="6dp"
            android:text="2026"
            android:textColor="#4A4F72"
            android:textSize="10sp" />

        <TextView
            android:id="@+id/widget_week_range"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text=""
            android:textColor="#4A4F72"
            android:textSize="9sp" />

    </LinearLayout>

    <!-- ── Week strip ── -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingLeft="8dp"
        android:paddingRight="8dp">

        <!-- DOW header row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <TextView android:id="@+id/widget_dow_0"
                android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"
                android:gravity="center" android:text="일"
                android:textSize="9sp" android:textColor="#FF2D55"
                android:paddingBottom="2dp" />
            <TextView android:id="@+id/widget_dow_1"
                android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"
                android:gravity="center" android:text="월"
                android:textSize="9sp" android:textColor="#4A4F72"
                android:paddingBottom="2dp" />
            <TextView android:id="@+id/widget_dow_2"
                android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"
                android:gravity="center" android:text="화"
                android:textSize="9sp" android:textColor="#4A4F72"
                android:paddingBottom="2dp" />
            <TextView android:id="@+id/widget_dow_3"
                android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"
                android:gravity="center" android:text="수"
                android:textSize="9sp" android:textColor="#4A4F72"
                android:paddingBottom="2dp" />
            <TextView android:id="@+id/widget_dow_4"
                android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"
                android:gravity="center" android:text="목"
                android:textSize="9sp" android:textColor="#4A4F72"
                android:paddingBottom="2dp" />
            <TextView android:id="@+id/widget_dow_5"
                android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"
                android:gravity="center" android:text="금"
                android:textSize="9sp" android:textColor="#4A4F72"
                android:paddingBottom="2dp" />
            <TextView android:id="@+id/widget_dow_6"
                android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"
                android:gravity="center" android:text="토"
                android:textSize="9sp" android:textColor="#00FFE7"
                android:paddingBottom="2dp" />

        </LinearLayout>

        <!-- Day number row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <!-- Day 0: Sunday -->
            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:orientation="vertical" android:gravity="center">
                <TextView android:id="@+id/widget_num_0"
                    android:layout_width="26dp" android:layout_height="26dp"
                    android:gravity="center" android:text="--"
                    android:textSize="12sp" android:textColor="#FF2D55" />
                <TextView android:id="@+id/widget_dot_0"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="●" android:textSize="5sp" android:textColor="#00FFE7"
                    android:visibility="invisible" android:layout_marginTop="1dp" />
            </LinearLayout>

            <!-- Day 1: Monday -->
            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:orientation="vertical" android:gravity="center">
                <TextView android:id="@+id/widget_num_1"
                    android:layout_width="26dp" android:layout_height="26dp"
                    android:gravity="center" android:text="--"
                    android:textSize="12sp" android:textColor="#8891B4" />
                <TextView android:id="@+id/widget_dot_1"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="●" android:textSize="5sp" android:textColor="#00FFE7"
                    android:visibility="invisible" android:layout_marginTop="1dp" />
            </LinearLayout>

            <!-- Day 2: Tuesday -->
            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:orientation="vertical" android:gravity="center">
                <TextView android:id="@+id/widget_num_2"
                    android:layout_width="26dp" android:layout_height="26dp"
                    android:gravity="center" android:text="--"
                    android:textSize="12sp" android:textColor="#8891B4" />
                <TextView android:id="@+id/widget_dot_2"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="●" android:textSize="5sp" android:textColor="#00FFE7"
                    android:visibility="invisible" android:layout_marginTop="1dp" />
            </LinearLayout>

            <!-- Day 3: Wednesday -->
            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:orientation="vertical" android:gravity="center">
                <TextView android:id="@+id/widget_num_3"
                    android:layout_width="26dp" android:layout_height="26dp"
                    android:gravity="center" android:text="--"
                    android:textSize="12sp" android:textColor="#8891B4" />
                <TextView android:id="@+id/widget_dot_3"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="●" android:textSize="5sp" android:textColor="#00FFE7"
                    android:visibility="invisible" android:layout_marginTop="1dp" />
            </LinearLayout>

            <!-- Day 4: Thursday -->
            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:orientation="vertical" android:gravity="center">
                <TextView android:id="@+id/widget_num_4"
                    android:layout_width="26dp" android:layout_height="26dp"
                    android:gravity="center" android:text="--"
                    android:textSize="12sp" android:textColor="#8891B4" />
                <TextView android:id="@+id/widget_dot_4"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="●" android:textSize="5sp" android:textColor="#00FFE7"
                    android:visibility="invisible" android:layout_marginTop="1dp" />
            </LinearLayout>

            <!-- Day 5: Friday -->
            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:orientation="vertical" android:gravity="center">
                <TextView android:id="@+id/widget_num_5"
                    android:layout_width="26dp" android:layout_height="26dp"
                    android:gravity="center" android:text="--"
                    android:textSize="12sp" android:textColor="#8891B4" />
                <TextView android:id="@+id/widget_dot_5"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="●" android:textSize="5sp" android:textColor="#00FFE7"
                    android:visibility="invisible" android:layout_marginTop="1dp" />
            </LinearLayout>

            <!-- Day 6: Saturday -->
            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:orientation="vertical" android:gravity="center">
                <TextView android:id="@+id/widget_num_6"
                    android:layout_width="26dp" android:layout_height="26dp"
                    android:gravity="center" android:text="--"
                    android:textSize="12sp" android:textColor="#00FFE7" />
                <TextView android:id="@+id/widget_dot_6"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="●" android:textSize="5sp" android:textColor="#00FFE7"
                    android:visibility="invisible" android:layout_marginTop="1dp" />
            </LinearLayout>

        </LinearLayout>
    </LinearLayout>

    <!-- ── Divider ── -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:layout_marginLeft="14dp"
        android:layout_marginRight="14dp"
        android:layout_marginTop="6dp"
        android:layout_marginBottom="4dp"
        android:background="#1E2140" />

    <!-- ── Today label ── -->
    <TextView
        android:id="@+id/widget_today_label"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingLeft="14dp"
        android:paddingRight="14dp"
        android:paddingBottom="4dp"
        android:text="오늘"
        android:textColor="#4A4F72"
        android:textSize="9sp" />

    <!-- ── Todo items (static, up to 4) ── -->

    <!-- Item 0 -->
    <LinearLayout
        android:id="@+id/widget_item_0"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingLeft="14dp"
        android:paddingRight="14dp"
        android:paddingTop="5dp"
        android:paddingBottom="5dp"
        android:visibility="gone">

        <View
            android:id="@+id/widget_item_0_bar"
            android:layout_width="3dp"
            android:layout_height="28dp"
            android:layout_marginRight="10dp"
            android:background="#00FFE7" />

        <TextView
            android:id="@+id/widget_item_0_title"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text=""
            android:textColor="#E0FFFFFF"
            android:textSize="12sp"
            android:singleLine="true"
            android:ellipsize="end" />

        <TextView
            android:id="@+id/widget_item_0_time"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginLeft="6dp"
            android:text=""
            android:textColor="#4A4F72"
            android:textSize="10sp" />

    </LinearLayout>

    <!-- Item 1 -->
    <LinearLayout
        android:id="@+id/widget_item_1"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingLeft="14dp"
        android:paddingRight="14dp"
        android:paddingTop="5dp"
        android:paddingBottom="5dp"
        android:visibility="gone">

        <View
            android:id="@+id/widget_item_1_bar"
            android:layout_width="3dp"
            android:layout_height="28dp"
            android:layout_marginRight="10dp"
            android:background="#00FFE7" />

        <TextView
            android:id="@+id/widget_item_1_title"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text=""
            android:textColor="#E0FFFFFF"
            android:textSize="12sp"
            android:singleLine="true"
            android:ellipsize="end" />

        <TextView
            android:id="@+id/widget_item_1_time"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginLeft="6dp"
            android:text=""
            android:textColor="#4A4F72"
            android:textSize="10sp" />

    </LinearLayout>

    <!-- Item 2 -->
    <LinearLayout
        android:id="@+id/widget_item_2"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingLeft="14dp"
        android:paddingRight="14dp"
        android:paddingTop="5dp"
        android:paddingBottom="5dp"
        android:visibility="gone">

        <View
            android:id="@+id/widget_item_2_bar"
            android:layout_width="3dp"
            android:layout_height="28dp"
            android:layout_marginRight="10dp"
            android:background="#00FFE7" />

        <TextView
            android:id="@+id/widget_item_2_title"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text=""
            android:textColor="#E0FFFFFF"
            android:textSize="12sp"
            android:singleLine="true"
            android:ellipsize="end" />

        <TextView
            android:id="@+id/widget_item_2_time"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginLeft="6dp"
            android:text=""
            android:textColor="#4A4F72"
            android:textSize="10sp" />

    </LinearLayout>

    <!-- Item 3 -->
    <LinearLayout
        android:id="@+id/widget_item_3"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingLeft="14dp"
        android:paddingRight="14dp"
        android:paddingTop="5dp"
        android:paddingBottom="5dp"
        android:visibility="gone">

        <View
            android:id="@+id/widget_item_3_bar"
            android:layout_width="3dp"
            android:layout_height="28dp"
            android:layout_marginRight="10dp"
            android:background="#00FFE7" />

        <TextView
            android:id="@+id/widget_item_3_title"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text=""
            android:textColor="#E0FFFFFF"
            android:textSize="12sp"
            android:singleLine="true"
            android:ellipsize="end" />

        <TextView
            android:id="@+id/widget_item_3_time"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginLeft="6dp"
            android:text=""
            android:textColor="#4A4F72"
            android:textSize="10sp" />

    </LinearLayout>

    <!-- More indicator -->
    <TextView
        android:id="@+id/widget_more"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingLeft="14dp"
        android:paddingTop="2dp"
        android:text=""
        android:textColor="#4A4F72"
        android:textSize="10sp"
        android:visibility="gone" />

    <!-- Empty state -->
    <TextView
        android:id="@+id/widget_empty"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:paddingTop="12dp"
        android:paddingBottom="12dp"
        android:text="오늘 일정이 없어요"
        android:textColor="#4A4F72"
        android:textSize="11sp"
        android:visibility="gone" />

</LinearLayout>
