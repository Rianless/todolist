<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#0D0F1E"
    android:padding="12dp">

    <!-- Week strip -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <!-- Day 0: 일 (Sun) -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center">
            <TextView
                android:id="@+id/dow_0"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="일"
                android:textSize="10sp"
                android:textColor="#FF2D55"/>
            <TextView
                android:id="@+id/date_0"
                android:layout_width="26dp"
                android:layout_height="26dp"
                android:gravity="center"
                android:textSize="12sp"
                android:textColor="#CDD6F4"
                android:layout_marginTop="2dp"/>
            <View
                android:id="@+id/dot_0"
                android:layout_width="4dp"
                android:layout_height="4dp"
                android:layout_marginTop="3dp"
                android:background="@drawable/dot_event"
                android:visibility="invisible"/>
        </LinearLayout>

        <!-- Day 1: 월 (Mon) -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center">
            <TextView
                android:id="@+id/dow_1"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="월"
                android:textSize="10sp"
                android:textColor="#8891B4"/>
            <TextView
                android:id="@+id/date_1"
                android:layout_width="26dp"
                android:layout_height="26dp"
                android:gravity="center"
                android:textSize="12sp"
                android:textColor="#CDD6F4"
                android:layout_marginTop="2dp"/>
            <View
                android:id="@+id/dot_1"
                android:layout_width="4dp"
                android:layout_height="4dp"
                android:layout_marginTop="3dp"
                android:background="@drawable/dot_event"
                android:visibility="invisible"/>
        </LinearLayout>

        <!-- Day 2: 화 (Tue) -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center">
            <TextView
                android:id="@+id/dow_2"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="화"
                android:textSize="10sp"
                android:textColor="#8891B4"/>
            <TextView
                android:id="@+id/date_2"
                android:layout_width="26dp"
                android:layout_height="26dp"
                android:gravity="center"
                android:textSize="12sp"
                android:textColor="#CDD6F4"
                android:layout_marginTop="2dp"/>
            <View
                android:id="@+id/dot_2"
                android:layout_width="4dp"
                android:layout_height="4dp"
                android:layout_marginTop="3dp"
                android:background="@drawable/dot_event"
                android:visibility="invisible"/>
        </LinearLayout>

        <!-- Day 3: 수 (Wed) -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center">
            <TextView
                android:id="@+id/dow_3"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="수"
                android:textSize="10sp"
                android:textColor="#8891B4"/>
            <TextView
                android:id="@+id/date_3"
                android:layout_width="26dp"
                android:layout_height="26dp"
                android:gravity="center"
                android:textSize="12sp"
                android:textColor="#CDD6F4"
                android:layout_marginTop="2dp"/>
            <View
                android:id="@+id/dot_3"
                android:layout_width="4dp"
                android:layout_height="4dp"
                android:layout_marginTop="3dp"
                android:background="@drawable/dot_event"
                android:visibility="invisible"/>
        </LinearLayout>

        <!-- Day 4: 목 (Thu) -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center">
            <TextView
                android:id="@+id/dow_4"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="목"
                android:textSize="10sp"
                android:textColor="#8891B4"/>
            <TextView
                android:id="@+id/date_4"
                android:layout_width="26dp"
                android:layout_height="26dp"
                android:gravity="center"
                android:textSize="12sp"
                android:textColor="#CDD6F4"
                android:layout_marginTop="2dp"/>
            <View
                android:id="@+id/dot_4"
                android:layout_width="4dp"
                android:layout_height="4dp"
                android:layout_marginTop="3dp"
                android:background="@drawable/dot_event"
                android:visibility="invisible"/>
        </LinearLayout>

        <!-- Day 5: 금 (Fri) -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center">
            <TextView
                android:id="@+id/dow_5"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="금"
                android:textSize="10sp"
                android:textColor="#8891B4"/>
            <TextView
                android:id="@+id/date_5"
                android:layout_width="26dp"
                android:layout_height="26dp"
                android:gravity="center"
                android:textSize="12sp"
                android:textColor="#CDD6F4"
                android:layout_marginTop="2dp"/>
            <View
                android:id="@+id/dot_5"
                android:layout_width="4dp"
                android:layout_height="4dp"
                android:layout_marginTop="3dp"
                android:background="@drawable/dot_event"
                android:visibility="invisible"/>
        </LinearLayout>

        <!-- Day 6: 토 (Sat) -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center">
            <TextView
                android:id="@+id/dow_6"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="토"
                android:textSize="10sp"
                android:textColor="#00FFE7"/>
            <TextView
                android:id="@+id/date_6"
                android:layout_width="26dp"
                android:layout_height="26dp"
                android:gravity="center"
                android:textSize="12sp"
                android:textColor="#CDD6F4"
                android:layout_marginTop="2dp"/>
            <View
                android:id="@+id/dot_6"
                android:layout_width="4dp"
                android:layout_height="4dp"
                android:layout_marginTop="3dp"
                android:background="@drawable/dot_event"
                android:visibility="invisible"/>
        </LinearLayout>

    </LinearLayout>

    <!-- Divider -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:layout_marginTop="8dp"
        android:layout_marginBottom="6dp"
        android:background="#1A1D3A"/>

    <!-- Todo row 0 -->
    <LinearLayout
        android:id="@+id/todo_row_0"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingTop="3dp"
        android:paddingBottom="3dp"
        android:visibility="gone">
        <TextView
            android:id="@+id/todo_time_0"
            android:layout_width="36dp"
            android:layout_height="wrap_content"
            android:textSize="10sp"
            android:textColor="#00FFE7"/>
        <TextView
            android:id="@+id/todo_title_0"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="4dp"
            android:textSize="11sp"
            android:textColor="#CDD6F4"
            android:ellipsize="end"
            android:maxLines="1"/>
    </LinearLayout>

    <!-- Todo row 1 -->
    <LinearLayout
        android:id="@+id/todo_row_1"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingTop="3dp"
        android:paddingBottom="3dp"
        android:visibility="gone">
        <TextView
            android:id="@+id/todo_time_1"
            android:layout_width="36dp"
            android:layout_height="wrap_content"
            android:textSize="10sp"
            android:textColor="#00FFE7"/>
        <TextView
            android:id="@+id/todo_title_1"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="4dp"
            android:textSize="11sp"
            android:textColor="#CDD6F4"
            android:ellipsize="end"
            android:maxLines="1"/>
    </LinearLayout>

    <!-- Todo row 2 -->
    <LinearLayout
        android:id="@+id/todo_row_2"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingTop="3dp"
        android:paddingBottom="3dp"
        android:visibility="gone">
        <TextView
            android:id="@+id/todo_time_2"
            android:layout_width="36dp"
            android:layout_height="wrap_content"
            android:textSize="10sp"
            android:textColor="#00FFE7"/>
        <TextView
            android:id="@+id/todo_title_2"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="4dp"
            android:textSize="11sp"
            android:textColor="#CDD6F4"
            android:ellipsize="end"
            android:maxLines="1"/>
    </LinearLayout>

    <!-- Todo row 3 -->
    <LinearLayout
        android:id="@+id/todo_row_3"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingTop="3dp"
        android:paddingBottom="3dp"
        android:visibility="gone">
        <TextView
            android:id="@+id/todo_time_3"
            android:layout_width="36dp"
            android:layout_height="wrap_content"
            android:textSize="10sp"
            android:textColor="#00FFE7"/>
        <TextView
            android:id="@+id/todo_title_3"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="4dp"
            android:textSize="11sp"
            android:textColor="#CDD6F4"
            android:ellipsize="end"
            android:maxLines="1"/>
    </LinearLayout>

</LinearLayout>
