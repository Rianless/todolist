<?xml version="1.0" encoding="utf-8"?>
<!-- Game quest log item: ▶01 [CATEGORY] title ··· time -->
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_item_root"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:paddingTop="6dp"
    android:paddingBottom="6dp"
    android:paddingEnd="10dp">

    <!-- Left color bar -->
    <View
        android:id="@+id/widget_item_accent"
        android:layout_width="2dp"
        android:layout_height="match_parent"
        android:minHeight="30dp"
        android:background="@drawable/bg_accent_bar" />

    <!-- Status glyph: ▶ active / ✓ done -->
    <TextView
        android:id="@+id/widget_item_status"
        android:layout_width="14dp"
        android:layout_height="wrap_content"
        android:text="▶"
        android:textSize="8sp"
        android:fontFamily="monospace"
        android:textColor="#00ffe7"
        android:gravity="center"
        android:layout_marginHorizontal="4dp" />

    <!-- Item number: 01 02 ... -->
    <TextView
        android:id="@+id/widget_item_num"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="01"
        android:textSize="8sp"
        android:fontFamily="monospace"
        android:textColor="#4a4f72"
        android:layout_marginEnd="6dp" />

    <!-- Content -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical">

        <!-- Category + time row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="1dp">

            <!-- [CATEGORY] tag -->
            <TextView
                android:id="@+id/widget_item_category"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="7sp"
                android:fontFamily="monospace"
                android:textColor="#00ffe7"
                android:letterSpacing="0.05" />

            <!-- Time -->
            <TextView
                android:id="@+id/widget_item_time"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="end"
                android:textSize="8sp"
                android:fontFamily="monospace"
                android:textColor="#4a4f72" />

        </LinearLayout>

        <!-- Title -->
        <TextView
            android:id="@+id/widget_item_title"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="12sp"
            android:textColor="#e8eaf6"
            android:fontFamily="monospace"
            android:singleLine="true"
            android:ellipsize="end" />

    </LinearLayout>

    <!-- Check box -->
    <TextView
        android:id="@+id/widget_item_check"
        android:layout_width="15dp"
        android:layout_height="15dp"
        android:layout_marginStart="6dp"
        android:gravity="center"
        android:textSize="8sp"
        android:textColor="#00ffe7"
        android:fontFamily="monospace"
        android:background="@drawable/bg_widget_check" />

</LinearLayout>
