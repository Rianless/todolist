<?xml version="1.0" encoding="utf-8"?>
<!-- Cyberpunk todo item -->
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_item_root"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:paddingHorizontal="12dp"
    android:paddingVertical="6dp">

    <!-- Neon color accent bar -->
    <View
        android:id="@+id/widget_item_accent"
        android:layout_width="3dp"
        android:layout_height="32dp"
        android:layout_marginEnd="10dp"
        android:background="@drawable/bg_accent_bar" />

    <!-- Content -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical">

        <!-- Category + Time row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="1dp">

            <TextView
                android:id="@+id/widget_item_category"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="8sp"
                android:textColor="#FFFF00FF"
                android:fontFamily="monospace"
                android:letterSpacing="0.1" />

            <TextView
                android:id="@+id/widget_item_time"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="end"
                android:textSize="8sp"
                android:textColor="#8000E5FF"
                android:fontFamily="monospace" />

        </LinearLayout>

        <!-- Title -->
        <TextView
            android:id="@+id/widget_item_title"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="12sp"
            android:textColor="#FFFFFFFF"
            android:fontFamily="monospace"
            android:singleLine="true"
            android:ellipsize="end" />

    </LinearLayout>

    <!-- Check box -->
    <TextView
        android:id="@+id/widget_item_check"
        android:layout_width="18dp"
        android:layout_height="18dp"
        android:layout_marginStart="8dp"
        android:gravity="center"
        android:textSize="10sp"
        android:textColor="#FF00E5FF"
        android:fontFamily="monospace"
        android:background="@drawable/bg_widget_check" />

</LinearLayout>
