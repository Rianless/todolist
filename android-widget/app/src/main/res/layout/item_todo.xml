<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/card_root"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="14dp"
    android:layout_marginVertical="5dp"
    app:cardBackgroundColor="@color/surface_card"
    app:cardCornerRadius="16dp"
    app:cardElevation="2dp"
    app:strokeColor="@color/border_subtle"
    app:strokeWidth="0.5dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <!-- Color accent bar -->
        <View
            android:id="@+id/view_accent"
            android:layout_width="4dp"
            android:layout_height="match_parent"
            android:minHeight="56dp"
            android:background="@color/ios_blue" />

        <!-- Content -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:padding="12dp">

            <!-- Category + Time -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="4dp">

                <TextView
                    android:id="@+id/tv_category"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:paddingHorizontal="7dp"
                    android:paddingVertical="2dp"
                    android:textSize="10sp"
                    android:fontFamily="sans-serif-medium"
                    android:background="@drawable/bg_category_pill"
                    android:textColor="@color/text_primary" />

                <TextView
                    android:id="@+id/tv_time"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="0dp"
                    android:layout_gravity="end"
                    android:layout_weight="1"
                    android:gravity="end"
                    android:textSize="11sp"
                    android:textColor="@color/text_tertiary"
                    android:fontFamily="sans-serif-medium" />

            </LinearLayout>

            <!-- Title -->
            <TextView
                android:id="@+id/tv_title"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="14sp"
                android:fontFamily="sans-serif-medium"
                android:textColor="@color/text_primary"
                android:lineSpacingMultiplier="1.3"
                android:layout_marginBottom="3dp" />

            <!-- Meta (instructor, location) -->
            <TextView
                android:id="@+id/tv_meta"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="11sp"
                android:textColor="@color/text_tertiary"
                android:singleLine="true"
                android:ellipsize="end" />

        </LinearLayout>

        <!-- Check button -->
        <TextView
            android:id="@+id/tv_check"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:layout_marginEnd="14dp"
            android:gravity="center"
            android:textSize="11sp"
            android:textColor="@android:color/white"
            android:background="@drawable/bg_check_empty" />

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>
