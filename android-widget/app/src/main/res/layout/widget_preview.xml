<?xml version="1.0" encoding="utf-8"?>
<!-- Static preview layout for widget picker (no ListView) -->
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@drawable/widget_background"
    android:padding="0dp">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingLeft="14dp"
        android:paddingRight="14dp"
        android:paddingTop="12dp"
        android:paddingBottom="8dp">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="오늘"
                android:textSize="17sp"
                android:fontFamily="sans-serif-medium"
                android:textColor="#FFFFFF"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="1/3 완료"
                android:textSize="12sp"
                android:textColor="#B0FFFFFF" />

        </LinearLayout>

        <TextView
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:text="＋"
            android:textSize="18sp"
            android:textColor="#FFFFFFFF"
            android:gravity="center"
            android:background="@drawable/bg_widget_btn" />

    </LinearLayout>

    <!-- Divider -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:layout_marginLeft="14dp"
        android:layout_marginRight="14dp"
        android:background="#33FFFFFF" />

    <!-- Sample item 1 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingLeft="14dp"
        android:paddingRight="14dp"
        android:paddingTop="7dp"
        android:paddingBottom="7dp">

        <View
            android:layout_width="4dp"
            android:layout_height="36dp"
            android:layout_marginRight="10dp"
            android:background="#007AFF" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="개인"
                android:textSize="9sp"
                android:textColor="#B0FFFFFF" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="오늘의 할 일"
                android:textSize="13sp"
                android:textColor="#F0FFFFFF"
                android:singleLine="true" />

        </LinearLayout>

    </LinearLayout>

    <!-- Sample item 2 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingLeft="14dp"
        android:paddingRight="14dp"
        android:paddingTop="7dp"
        android:paddingBottom="7dp">

        <View
            android:layout_width="4dp"
            android:layout_height="36dp"
            android:layout_marginRight="10dp"
            android:background="#5856D6" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="업무"
                android:textSize="9sp"
                android:textColor="#B0FFFFFF" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="중요한 미팅"
                android:textSize="13sp"
                android:textColor="#F0FFFFFF"
                android:singleLine="true" />

        </LinearLayout>

    </LinearLayout>

    <!-- Sample item 3 (done) -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingLeft="14dp"
        android:paddingRight="14dp"
        android:paddingTop="7dp"
        android:paddingBottom="7dp">

        <View
            android:layout_width="4dp"
            android:layout_height="36dp"
            android:layout_marginRight="10dp"
            android:background="#34C759" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="기타"
                android:textSize="9sp"
                android:textColor="#B0FFFFFF" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="완료된 할 일"
                android:textSize="13sp"
                android:textColor="#73FFFFFF"
                android:singleLine="true" />

        </LinearLayout>

    </LinearLayout>

</LinearLayout>
