<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#0D0F1E"
    android:padding="12dp">

    <!-- Week strip preview -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1" android:orientation="vertical" android:gravity="center">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="일" android:textSize="10sp" android:textColor="#FF2D55"/>
            <TextView android:layout_width="26dp" android:layout_height="26dp"
                android:gravity="center" android:text="6" android:textSize="12sp"
                android:textColor="#CDD6F4" android:layout_marginTop="2dp"/>
        </LinearLayout>

        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1" android:orientation="vertical" android:gravity="center">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="월" android:textSize="10sp" android:textColor="#8891B4"/>
            <TextView android:layout_width="26dp" android:layout_height="26dp"
                android:gravity="center" android:text="7" android:textSize="12sp"
                android:textColor="#CDD6F4" android:layout_marginTop="2dp"/>
        </LinearLayout>

        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1" android:orientation="vertical" android:gravity="center">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="화" android:textSize="10sp" android:textColor="#8891B4"/>
            <TextView android:layout_width="26dp" android:layout_height="26dp"
                android:gravity="center" android:text="8" android:textSize="12sp"
                android:textColor="#CDD6F4" android:layout_marginTop="2dp"/>
        </LinearLayout>

        <!-- Today: Wed 9, cyan circle -->
        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1" android:orientation="vertical" android:gravity="center">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="수" android:textSize="10sp" android:textColor="#8891B4"/>
            <TextView android:layout_width="26dp" android:layout_height="26dp"
                android:gravity="center" android:text="9" android:textSize="12sp"
                android:textColor="#06070F" android:layout_marginTop="2dp"
                android:background="@drawable/widget_day_today_bg"/>
        </LinearLayout>

        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1" android:orientation="vertical" android:gravity="center">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="목" android:textSize="10sp" android:textColor="#8891B4"/>
            <TextView android:layout_width="26dp" android:layout_height="26dp"
                android:gravity="center" android:text="10" android:textSize="12sp"
                android:textColor="#CDD6F4" android:layout_marginTop="2dp"/>
        </LinearLayout>

        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1" android:orientation="vertical" android:gravity="center">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="금" android:textSize="10sp" android:textColor="#8891B4"/>
            <TextView android:layout_width="26dp" android:layout_height="26dp"
                android:gravity="center" android:text="11" android:textSize="12sp"
                android:textColor="#CDD6F4" android:layout_marginTop="2dp"/>
        </LinearLayout>

        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1" android:orientation="vertical" android:gravity="center">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="토" android:textSize="10sp" android:textColor="#00FFE7"/>
            <TextView android:layout_width="26dp" android:layout_height="26dp"
                android:gravity="center" android:text="12" android:textSize="12sp"
                android:textColor="#CDD6F4" android:layout_marginTop="2dp"/>
        </LinearLayout>

    </LinearLayout>

    <View android:layout_width="match_parent" android:layout_height="1dp"
        android:layout_marginTop="8dp" android:layout_marginBottom="6dp"
        android:background="#1A1D3A"/>

    <!-- Preview todos -->
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="horizontal" android:paddingTop="3dp" android:paddingBottom="3dp">
        <TextView android:layout_width="36dp" android:layout_height="wrap_content"
            android:text="09:00" android:textSize="10sp" android:textColor="#00FFE7"/>
        <TextView android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1" android:layout_marginStart="4dp"
            android:text="팀 스탠드업 미팅" android:textSize="11sp" android:textColor="#CDD6F4"/>
    </LinearLayout>

    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="horizontal" android:paddingTop="3dp" android:paddingBottom="3dp">
        <TextView android:layout_width="36dp" android:layout_height="wrap_content"
            android:text="종일" android:textSize="10sp" android:textColor="#00FFE7"/>
        <TextView android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1" android:layout_marginStart="4dp"
            android:text="코드 리뷰 완료" android:textSize="11sp" android:textColor="#CDD6F4"/>
    </LinearLayout>

</LinearLayout>
